# Runtime mode
ENABLE_DATABASE=true
DEMO_MODE=false

# Polling
POLL_INTERVAL_SECONDS=18
EXCEL_FILE=logs/Energy_Log.xlsx
APP_TIMEZONE=Asia/Calcutta
METER_CLOCK_MAX_DRIFT_SECONDS=120

# API
API_HOST=127.0.0.1
API_PORT=5000
API_DEBUG=false
API_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
API_KEY_ENABLED=false
API_KEY=replace_me
VITE_API_BASE_URL=
VITE_API_KEY=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=energy_monitoring
DB_USER=postgres
DB_PASSWORD=replace_me
DB_CONNECT_TIMEOUT_SECONDS=5

# Readings retention
# Set READINGS_RETENTION_DAYS=0 to disable automatic cleanup.
READINGS_RETENTION_DAYS=1825
READINGS_CLEANUP_BATCH_SIZE=5000
READINGS_CLEANUP_INTERVAL_HOURS=1

# Durable local queue used while PostgreSQL is unavailable
READING_SPOOL_PATH=data/reading_spool.sqlite3
READING_SPOOL_MAX_ROWS=100000
READING_SPOOL_MAX_ROWS_PER_METER=50000
READING_SPOOL_RETENTION_DAYS=30
READING_SPOOL_REPLAY_BATCH_SIZE=500

# Scheduled report/email worker
REPORT_WORKER_ENABLED=true
REPORT_WORKER_INTERVAL_SECONDS=15

# SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=replace_me
SMTP_FROM_EMAIL=alerts@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
