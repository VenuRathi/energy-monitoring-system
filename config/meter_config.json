{
  "meter_defaults": {
    "manufacturer": "Schneider",
    "model": "PM5000-EM6400",
    "protocol": "modbus_rtu",
    "enabled": true,
    "driver": "schneider.pm5000",
    "meter_timestamp_parameter": "Present Date & Time"
  },
  "connection_defaults": {
    "baud_rate": 9600,
    "parity": "N",
    "stop_bits": 1,
    "byte_size": 8,
    "timeout": 2.0,
    "one_based_map": true
  },
  "parameter_sets": {
    "schneider_pm5000_core": [
        {"name": "Current A", "register": 3000, "type": "float32", "unit": "A", "scale": 1.0},
        {"name": "Current B", "register": 3002, "type": "float32", "unit": "A", "scale": 1.0},
        {"name": "Current C", "register": 3004, "type": "float32", "unit": "A", "scale": 1.0},
        {"name": "Current N", "register": 3006, "type": "float32", "unit": "A", "scale": 1.0},
