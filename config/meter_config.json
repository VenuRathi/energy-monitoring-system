        {"name": "Power Factor Total", "register": 3084, "type": "float32", "unit": "PF", "scale": 1.0},

        {"name": "Displacement Power Factor A", "register": 3086, "type": "float32", "unit": "PF", "scale": 1.0},
        {"name": "Displacement Power Factor B", "register": 3088, "type": "float32", "unit": "PF", "scale": 1.0},
        {"name": "Displacement Power Factor C", "register": 3090, "type": "float32", "unit": "PF", "scale": 1.0},
        {"name": "Displacement Power Factor Total", "register": 3092, "type": "float32", "unit": "PF", "scale": 1.0},

        {"name": "Frequency", "register": 3110, "type": "float32", "unit": "Hz", "scale": 1.0},

        {"name": "Power Factor Total IEC", "register": 3192, "type": "float32", "unit": "PF", "scale": 1.0},
        {"name": "Power Factor Total Lead Lag", "register": 3194, "type": "float32", "unit": "PF", "scale": 1.0},
        {"name": "Power Factor Total IEC Code", "register": 3196, "type": "uint16", "unit": "code", "scale": 1.0},
        {"name": "Power Factor Total Lead Lag Code", "register": 3197, "type": "uint16", "unit": "code", "scale": 1.0},

        {"name": "Accumulated Energy Reset Date/Time", "register": 3200, "type": "datetime4", "unit": "raw", "scale": 1.0},
        {"name": "Present Date & Time", "register": 1845, "type": "datetime4", "unit": "raw", "scale": 1.0},

        {"name": "Active Energy Received (Out of Load)", "register": 3207, "type": "uint32", "unit": "kWh", "scale": 0.001},

        {"name": "Reactive Energy Received", "register": 3223, "type": "uint32", "unit": "kVARh", "scale": 0.001},

        {"name": "Apparent Energy Received", "register": 3239, "type": "uint32", "unit": "kVAh", "scale": 0.001},

        {"name": "Demand System Assignment", "register": 3793, "type": "uint16", "unit": "code", "scale": 1.0},
