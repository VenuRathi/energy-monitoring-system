        {"name": "Units Code", "register": 3795, "type": "uint16", "unit": "code", "scale": 1.0},

        {"name": "Last Demand", "register": 3796, "type": "float32", "unit": "kVA", "scale": 1.0},
        {"name": "Present Demand", "register": 3798, "type": "float32", "unit": "kVA", "scale": 1.0},
        {"name": "Predicted Demand", "register": 3800, "type": "float32", "unit": "kVA", "scale": 1.0},
        {"name": "Peak Demand", "register": 3802, "type": "float32", "unit": "kVA", "scale": 1.0},
        {"name": "Peak Demand DateTime", "register": 3804, "type": "datetime4", "unit": "raw", "scale": 1.0}
      ]
  },
  "meters": [
    {
      "meter_id": "MTR-001",
      "meter_name": "Main Schneider Meter",
      "location": "Panel-1",
      "enabled": true,
      "parameter_set": "schneider_pm5000_core",
      "connection": {
        "port": "COM5",
        "slave_id": 1
      }
    },
    {
      "meter_id": "MTR-002",
      "meter_name": "Second Meter Template",
      "location": "Panel-2",
      "enabled": true,
      "parameter_set": "schneider_pm5000_core",
      "connection": {
        "port": "COM7",
        "slave_id": 2
      }
    },
    {
      "meter_id": "MTR-003",
      "meter_name": "Meter 3",
      "location": "Panel-3",
      "enabled": false,
      "parameter_set": "schneider_pm5000_core",
      "connection": {
        "port": "COM6",
        "slave_id": 3
      }
    }
