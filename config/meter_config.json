        {"name": "Voltage Unbalance L-N Worst", "register": 3052, "type": "float32", "unit": "%", "scale": 1.0},

        {"name": "Active Power A", "register": 3054, "type": "float32", "unit": "kW", "scale": 1.0},
        {"name": "Active Power B", "register": 3056, "type": "float32", "unit": "kW", "scale": 1.0},
